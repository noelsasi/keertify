{
  "name": "keertify",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json}\" --ignore-path .prettierignore"
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "msw", "@biomejs/biome"]
  }
}
