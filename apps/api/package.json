{
  "name": "@keertify/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file=.env node_modules/drizzle-kit/bin.cjs push --force",
    "db:studio": "node --env-file=.env node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@hono/zod-validator": "^0.4.3",
    "@keertify/shared": "workspace:*",
    "@neondatabase/serverless": "^0.10.4",
    "@upstash/redis": "^1.34.9",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.7.11",
    "node-html-parser": "^7.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.30.2",
    "tsup": "^8.5.0",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3"
  }
}